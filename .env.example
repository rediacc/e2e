# E2E Test Environment Configuration
# Copy this file to .env and ensure all values are set correctly.
#
# IMPORTANT: Bridge test variables (VM_*, MONOREPO_ROOT, BRIDGE_TIMEOUT) are REQUIRED.
# Tests will fail with clear error messages if any required variable is missing.

# =============================================================================
# Monorepo Configuration (REQUIRED for bridge tests)
# =============================================================================

# Root path to the monorepo - used for building renet and running ops scripts
MONOREPO_ROOT=/home/muhammed/monorepo

# =============================================================================
# VM Network Configuration (REQUIRED for bridge tests)
# =============================================================================

# Network prefix for VMs (first 3 octets)
VM_NET_BASE=192.168.111

# Offset added to VM ID when calculating IP
VM_NET_OFFSET=0

# Bridge VM ID (IP = VM_NET_BASE + VM_BRIDGE = 192.168.111.1)
# Bridge VM is the SSH gateway - all commands route through it
VM_BRIDGE=1

# Worker VM IDs (space-separated)
# Workers execute repository, datastore, and container operations
VM_WORKERS=11 12

# Ceph node VM IDs (space-separated)
# Ceph nodes execute ceph_pool, ceph_image, ceph_snapshot, ceph_clone operations
VM_CEPH_NODES=21 22 23

# =============================================================================
# Timeouts (REQUIRED)
# =============================================================================

# Default bridge command timeout in milliseconds
BRIDGE_TIMEOUT=30000

# API and page timeouts for Playwright tests
API_TIMEOUT=5000
PAGE_TIMEOUT=5000
TEST_TIMEOUT=30000

# =============================================================================
# Application Under Test
# =============================================================================

# Base URL for web UI tests
BASE_URL=https://test.com

# Test user credentials
TEST_USER_EMAIL=test@test.com
TEST_USER_PASSWORD=test

# System admin credentials
SYSTEM_ADMIN_EMAIL=admin@rediacc.io
SYSTEM_ADMIN_PASSWORD=admin

# =============================================================================
# Test Environment
# =============================================================================

NODE_ENV=test
CI=false

# =============================================================================
# Browser Settings
# =============================================================================

BROWSER=chromium
HEADLESS=false
SLOW_MO=100

# =============================================================================
# Debugging
# =============================================================================

DEBUG=false
VERBOSE=false

# =============================================================================
# Test Data
# =============================================================================

USE_REAL_DATA=false
CLEANUP_TEST_DATA=true

# =============================================================================
# Screenshots
# =============================================================================

TAKE_SCREENSHOTS=true
SCREENSHOT_ON_FAILURE=true
FULL_PAGE_SCREENSHOTS=true

# =============================================================================
# Video Recording
# =============================================================================

RECORD_VIDEO=on-failure
VIDEO_SIZE_WIDTH=1440
VIDEO_SIZE_HEIGHT=900

# =============================================================================
# Reports
# =============================================================================

GENERATE_HTML_REPORT=true
GENERATE_JSON_REPORT=true
OPEN_REPORT_AFTER_TEST=false

# =============================================================================
# Parallel Execution
# =============================================================================

MAX_WORKERS=4
STOP_ON_FAILURE=false

# =============================================================================
# Bridge Test Execution Model
# =============================================================================
#
# All bridge tests execute via two-hop SSH:
#   Host Machine -> SSH -> Bridge VM -> SSH -> Target VM -> renet command
#
# Before each test run:
#   1. VMs are soft-reset via ops scripts (./go up_systems --force --parallel)
#   2. Renet binary is built and deployed to all VMs
#   3. All VMs are verified as ready (reachable + SSH + renet installed)
#
# VM assignments:
#   - Tests 01-07, 10-12: Worker VMs (192.168.111.11, 192.168.111.12)
#   - Tests 08-09 (Ceph): Ceph VMs (192.168.111.21, 192.168.111.22, 192.168.111.23)
#
# VM IPs are calculated dynamically:
#   - Bridge VM:  VM_NET_BASE + VM_BRIDGE        = 192.168.111.1
#   - Worker VM1: VM_NET_BASE + VM_WORKERS[0]    = 192.168.111.11
#   - Worker VM2: VM_NET_BASE + VM_WORKERS[1]    = 192.168.111.12
#   - Ceph VM1:   VM_NET_BASE + VM_CEPH_NODES[0] = 192.168.111.21
#   - Ceph VM2:   VM_NET_BASE + VM_CEPH_NODES[1] = 192.168.111.22
#   - Ceph VM3:   VM_NET_BASE + VM_CEPH_NODES[2] = 192.168.111.23

# =============================================================================
# Example Usage
# =============================================================================
#
# Bridge tests:
#   npm run test:bridge:all         # All bridge tests
#   npm run test:bridge:checks      # System checks only
#   npm run test:bridge:ceph        # Ceph operations only
#
# Web UI tests:
#   npm run test                    # All Playwright tests
#
# View reports:
#   npx playwright show-report
