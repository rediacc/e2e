{
  "name": "tester",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:debug": "playwright test --debug",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report reports/web",
    "test:codegen": "playwright codegen",
    "test:install": "playwright install",
    "test:install-deps": "playwright install-deps",
    "test:auth": "playwright test --grep @auth",
    "test:resources": "playwright test --grep @resources",
    "test:dashboard": "playwright test --grep @dashboard",
    "test:system": "playwright test --grep @system",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:bridge": "playwright test --config=playwright.bridge.config.ts --grep @bridge; python3 scripts/fix-report-order.py reports/bridge/index.html",
    "test:bridge:local": "playwright test --config=playwright.bridge.config.ts tests/bridge/local-executor.test.ts",
    "test:bridge:setup": "playwright test --config=playwright.bridge.config.ts tests/bridge/setup-command.test.ts",
    "test:bridge:checks": "playwright test --config=playwright.bridge.config.ts tests/bridge/01-system-checks.test.ts",
    "test:bridge:machine": "playwright test --config=playwright.bridge.config.ts tests/bridge/02-machine-setup.test.ts",
    "test:bridge:datastore": "playwright test --config=playwright.bridge.config.ts tests/bridge/03-datastore-lifecycle.test.ts",
    "test:bridge:repository": "playwright test --config=playwright.bridge.config.ts tests/bridge/04-repository-lifecycle.test.ts",
    "test:bridge:rediaccfiles": "playwright test --config=playwright.bridge.config.ts tests/bridge/05-rediaccfiles-updown.test.ts",
    "test:bridge:daemon": "playwright test --config=playwright.bridge.config.ts tests/bridge/06-daemon-operations.test.ts",
    "test:bridge:container": "playwright test --config=playwright.bridge.config.ts tests/bridge/07-container-operations.test.ts",
    "test:bridge:ceph": "playwright test --config=playwright.bridge.config.ts tests/bridge/08-ceph-pool-image.test.ts tests/bridge/09-ceph-snapshot-clone.test.ts",
    "test:bridge:ceph:pool": "playwright test --config=playwright.bridge.config.ts tests/bridge/08-ceph-pool-image.test.ts",
    "test:bridge:ceph:clone": "playwright test --config=playwright.bridge.config.ts tests/bridge/09-ceph-snapshot-clone.test.ts",
    "test:bridge:backup": "playwright test --config=playwright.bridge.config.ts tests/bridge/10-backup-checkpoint.test.ts",
    "test:bridge:multi": "playwright test --config=playwright.bridge.config.ts tests/bridge/11-multi-machine.test.ts",
    "test:bridge:integration": "playwright test --config=playwright.bridge.config.ts tests/bridge/12-full-integration.test.ts",
    "test:bridge:fork": "playwright test --config=playwright.bridge.config.ts tests/bridge/13-postgres-fork-isolation.test.ts",
    "test:bridge:vault": "playwright test --config=playwright.bridge.config.ts tests/bridge/14-vault-builder.test.ts",
    "test:bridge:storage": "playwright test --config=playwright.bridge.config.ts tests/bridge/15-storage-backup.test.ts",
    "test:bridge:lifecycle": "playwright test --config=playwright.bridge.config.ts --grep @lifecycle",
    "test:bridge:all": "playwright test --config=playwright.bridge.config.ts tests/bridge/; python3 scripts/fix-report-order.py reports/bridge/index.html",
    "test:bridge:report": "playwright show-report reports/bridge --port 9323",
    "fix:bridge:report": "python3 scripts/fix-report-order.py reports/bridge/index.html",
    "test:parallel": "playwright test --workers=4",
    "test:serial": "playwright test --workers=1",
    "clean:reports": "rimraf reports screenshots test-results",
    "clean:screenshots": "rimraf screenshots",
    "lint": "eslint src tests --ext .ts,.tsx",
    "lint:fix": "eslint src tests --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "setup": "npm run test:install && npm run test:install-deps",
    "ci": "npm run lint && npm run type-check && npm run test"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@playwright/test": "^1.56.1",
    "axios": "^1.6.8",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.5",
    "ssh2": "^1.16.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/ssh2": "^1.15.1",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^8.57.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3"
  }
}
